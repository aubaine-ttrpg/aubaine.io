# ────────────────────────────────────────────────────────────────────────────────
# 📖 Loading Order
# ────────────────────────────────────────────────────────────────────────────────
# Env files load earliest → latest, later wins:
#
#   1. .env                  — committed, defaults
#   2. .env.$APP_ENV         — committed, per-environment
#   3. .env.local            — gitignored, machine-specific
#   4. .env.$APP_ENV.local   — gitignored, machine + env
#   5. .env.local.php        — composer dump-env prod output
#
# System environment variables win over every .env file.
# Production secrets go through Symfony Secrets, not committed files:
# https://symfony.com/doc/current/configuration/secrets.html
# ────────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────────
# 🏗️ Symfony Framework
# ────────────────────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share

# ────────────────────────────────────────────────────────────────────────────────
# 🧭 Routing
# ────────────────────────────────────────────────────────────────────────────────
# URL generation in non-HTTP contexts (CLI commands).
# https://symfony.com/doc/current/routing.html#generating-urls-in-commands
# ────────────────────────────────────────────────────────────────────────────────
DEFAULT_URI=http://localhost

# ────────────────────────────────────────────────────────────────────────────────
# 🗃️ Database
# ────────────────────────────────────────────────────────────────────────────────
# DSN format: Doctrine DBAL configuration reference.
# https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html
# ────────────────────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite:///%kernel.project_dir%/db/app.db"
