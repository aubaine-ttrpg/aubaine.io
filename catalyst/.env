# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILE.
# Local overrides go in .env.dev (uncommitted). https://symfony.com/doc/current/configuration/secrets.html

# ─────────────────────────────────────────────────────────────
# 🏗️ Symfony Core
# ─────────────────────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=DEFAULT-SECRET-TO-CHANGE-IN-DEV-ENV-FILE
APP_SHARE_DIR=var/share

# ─────────────────────────────────────────────────────────────
# 🌍 Locale (FR primary, EN secondary — code and slugs stay English)
# ─────────────────────────────────────────────────────────────
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr|en

# ─────────────────────────────────────────────────────────────
# 🌐 Routing & URLs
# ─────────────────────────────────────────────────────────────
# Used to generate URLs in non-HTTP contexts, such as CLI commands.
DEFAULT_URI=http://localhost

# ─────────────────────────────────────────────────────────────
# 🖨️ PDF rendering (Gotenberg)
# ─────────────────────────────────────────────────────────────
# App -> Gotenberg. Overridden at runtime by the Symfony CLI from the Docker
# service (label com.symfony.server.service-prefix: GOTENBERG).
GOTENBERG_HOST=127.0.0.1
GOTENBERG_PORT=3000
# Gotenberg -> app. Base URL Gotenberg uses to fetch the print page. HTTPS
# because `symfony serve` serves TLS and redirects HTTP; the container ignores
# the local CA (see compose.yaml).
GOTENBERG_APP_URL=https://host.docker.internal:8000

# ─────────────────────────────────────────────────────────────
# ✨ Easter egg
# ─────────────────────────────────────────────────────────────
# The shiny logo appears at 1/4096 per hard page load. Set to 1 to force it on
# every load (demo/testing); keep such local overrides in .env.dev.
SHINY_FORCE=0
