<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{{ book.title }}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;900&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=Barlow+Semi+Condensed:wght@500;600;700&display=swap" rel="stylesheet">
        {{ encore_entry_link_tags('print') }}
    </head>
    <body class="print-doc">
        <div class="print-bar" data-controller="print">
            <a class="btn btn--ghost" href="{{ path('app_book_edit', {id: book.id}) }}">← {{ book.title }}</a>
            <button class="btn btn--primary" type="button" data-action="print#print">{{ 'book.print'|trans }}</button>
        </div>

        {% if pages is empty %}
            <p class="print-empty">{{ 'print.empty'|trans }}</p>
        {% endif %}

        {% for pageView in pages %}
            {{ include(pageView.template, pageView.view, with_context = false) }}
        {% endfor %}

        {{ encore_entry_script_tags('print') }}
    </body>
</html>
