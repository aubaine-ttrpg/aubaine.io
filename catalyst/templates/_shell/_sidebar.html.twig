{# Persistent second-level sidebar (every page): "New book" plus the books
   grouped into a collapsible per type. The rail picks the section; Books is the
   one built so far, so its list is what the sidebar shows. #}
{% set groups = nav_book_groups() %}
{% set total = nav_books()|length %}
<nav class="sidenav" id="sidenav" aria-label="{{ 'nav.books'|trans }}">
    <div class="sidenav__group">
        <div class="sidenav__head">
            <span>{{ 'nav.books'|trans }}</span><span>{{ total }}</span>
        </div>

        <a class="sidenav__item sidenav__item--new" href="{{ path('app_book_new') }}">
            <span class="sidenav__plus">+</span>
            <span class="sidenav__label">{{ 'book.list.new'|trans }}</span>
        </a>

        {% if total == 0 %}
            <p class="sidenav__empty">{{ 'book.list.empty.title'|trans }}</p>
        {% endif %}

        {% for group in groups %}
            {% set hasActive = group.books|filter(b => b.id == currentBookId)|length > 0 %}
            <details class="sidenav__collapse" {{ hasActive or currentBookId is null ? 'open' }}>
                <summary class="sidenav__collapse-summary">
                    <span class="sidenav__collapse-label">{{ group.labelKey|trans }}</span>
                    <span class="sidenav__tag">{{ group.count }}</span>
                </summary>
                {% for b in group.books %}
                    <a class="sidenav__item {{ b.id == currentBookId ? 'is-active' }}"
                       href="{{ path('app_book_edit', {id: b.id}) }}"
                       {{ b.id == currentBookId ? 'aria-current="true"' }}>
                        <span class="sidenav__dot"></span>
                        <span class="sidenav__label">{{ b.title }}</span>
                    </a>
                {% endfor %}
            </details>
        {% endfor %}
    </div>
</nav>
