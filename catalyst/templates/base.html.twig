<!DOCTYPE html>
{% set currentRoute = app.request.attributes.get('_route') %}
{% set current = currentRoute starts with 'app_book' ? 'books' : null %}
{% set currentBookId = app.request.attributes.get('id') %}
{% set sections = [
    { key: 'books',      label: 'nav.books'|trans,        route: 'app_book_index', enabled: true },
    { key: 'trees',      label: 'nav.skill_trees'|trans,  enabled: false },
    { key: 'skills',     label: 'nav.skills'|trans,       enabled: false },
    { key: 'species',    label: 'nav.species'|trans,      enabled: false },
    { key: 'tags',       label: 'nav.tags'|trans,         enabled: false },
    { key: 'archetypes', label: 'nav.archetypes'|trans,   enabled: false },
    { key: 'characters', label: 'nav.characters'|trans,   enabled: false },
] %}
<html lang="{{ app.request.locale|default('fr') }}" data-controller="transitions intro theme shiny sidebar"
      data-shiny-url-value="{{ asset('build/images/brand/aubaine-logo-shiny.svg') }}"
      data-shiny-force-value="{{ shiny_force ? 'true' : 'false' }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ 'app.name'|trans }}{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('build/images/brand/aubaine-logo.svg') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;900&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=Barlow+Semi+Condensed:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
        {% block stylesheets %}{{ encore_entry_link_tags('app') }}{% endblock %}
        {% block javascripts %}{{ encore_entry_script_tags('app') }}{% endblock %}
    </head>
    <body>
        <div class="app">
            <header class="topbar">
                <div class="topbar__brand">
                    <button type="button" class="topbar__theme-logo" data-action="theme#toggle"
                            aria-label="{{ 'nav.toggle_theme'|trans }}">
                        {{ include('_shell/_logo.html.twig') }}
                    </button>
                    <a class="topbar__brand-link" href="{{ path('app_landing') }}">
                        <span class="topbar__brand-name">Aubaine</span>
                        <span class="topbar__brand-sub">Catalyst</span>
                    </a>
                </div>
                <div class="topbar__nav">
                    <nav class="topbar__crumbs" id="crumbs" aria-label="{{ 'nav.breadcrumb'|trans }}">
                        {% block crumbs %}
                            <a class="topbar__crumb" href="{{ path('app_book_index') }}">{{ 'nav.books'|trans }}</a>
                            {% block crumb %}{% endblock %}
                        {% endblock %}
                    </nav>
                </div>
            </header>

            {{ include('_shell/_rail.html.twig', { sections, current }) }}
            {{ include('_shell/_sidebar.html.twig', { current, currentBookId }) }}

            <main id="stage" class="stage transition-veil">
                {% block stage %}
                    <div class="stage__inner {% block stage_class %}{% endblock %}">
                        {% for label, messages in app.flashes %}
                            {% for message in messages %}
                                <p class="flash flash--{{ label }}" role="status">{{ message|trans }}</p>
                            {% endfor %}
                        {% endfor %}

                        {% block body %}{% endblock %}
                    </div>
                {% endblock %}
            </main>

            <footer class="status-bar">
                <span class="status-bar__pulse"></span>
                <span>Aubaine Catalyst</span>
                {{ include('_shell/_language.html.twig') }}
            </footer>
        </div>
    </body>
</html>
