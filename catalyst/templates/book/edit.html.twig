{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} · {{ 'app.name'|trans }}{% endblock %}

{% block crumb %}
    <span class="topbar__crumb-sep">❯</span>
    <span class="topbar__crumb topbar__crumb--current">{{ book.title }}</span>
{% endblock %}

{% block stage_class %}stage__inner--wide{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <a class="back" href="{{ path('app_book_index') }}">← {{ 'book.list.title'|trans }}</a>
            <h1>{{ book.title }}</h1>
            {% if book.subtitle %}<p class="subtitle">{{ book.subtitle }}</p>{% endif %}
        </div>
        <div class="page-head__actions">
            <a class="btn btn--ghost" href="{{ path('app_book_settings', {id: book.id}) }}">
                {{ 'book.settings.title'|trans }}
            </a>
            <a class="btn btn--primary" href="{{ path('app_book_pdf', {id: book.id, download: 1}) }}" data-no-swup>
                {{ 'book.download_pdf'|trans }}
            </a>
        </div>
    </div>

    <twig:LiveBookEditor :bookId="book.id" :selectedPageId="selectedPageId" />
{% endblock %}
